# 应用配置
NODE_ENV=development
PORT=3000

# JWT配置
JWT_SECRET=your_jwt_secret_here_change_in_production_use_long_random_string

# 代理配置（用于反向代理环境）
# auto: 自动配置（生产环境信任第一层代理，开发环境不信任）
# 1: 信任第一层代理（推荐用于 Nginx/Apache）
# loopback: 仅信任本地回环地址
# true: 信任所有代理（不推荐）
# false: 不信任任何代理
# 具体IP: 127.0.0.1,::1,10.0.0.1（多个IP用逗号分隔）
TRUST_PROXY=auto

# 数据库配置
# SQLite默认使用本地文件，如果要迁移到PostgreSQL，配置以下选项
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=logistics_db
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password_if_needed
REDIS_DB=0

# 企业微信配置（可选）
# WECHAT_WEBHOOK_DEFAULT=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_DEFAULT_KEY

# 日志配置
LOG_LEVEL=info  # debug, info, warn, error
LOG_FILE_MAX_SIZE=10485760  # 10MB
LOG_FILE_MAX_FILES=5

# 性能配置
CACHE_TTL_DEFAULT=300  # 默认缓存时间（秒）
CACHE_TTL_ORDERS=600   # 订单缓存时间
CACHE_TTL_PROVIDERS=3600  # 供应商缓存时间

# 安全配置
RATE_LIMIT_WINDOW_MS=900000  # 15分钟
RATE_LIMIT_MAX_REQUESTS=100000  # 每个窗口期最大请求数（15分钟内100000次）
RATE_LIMIT_LOGIN_MAX=5      # 登录尝试限制
RATE_LIMIT_CREATE_ORDER_MAX=2000  # 创建订单限制（1小时内2000次）

# CORS配置（生产环境建议限制）
CORS_ORIGIN=*  # 生产环境改为具体域名，如 https://yourdomain.com

# Session配置（如果使用session）
SESSION_SECRET=your_session_secret_here_change_in_production

# 管理员密码（部署时设置）
# 这是管理后台 /admin 的登录密码
# 强烈建议设置一个强密码，避免使用默认值
# 如果不设置，系统将使用默认密码 admin123
APP_PASSWORD=your_secure_admin_password_here_change_this