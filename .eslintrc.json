{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "plugins": ["prettier"],
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "script"
  },
  "rules": {
    "prettier/prettier": "warn",
    "no-console": "off",
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "prefer-const": "warn",
    "no-var": "warn",
    "no-undef": "error",
    "no-unreachable": "error",
    "no-duplicate-imports": "warn",
    "no-useless-return": "warn",
    "consistent-return": "off",
    "curly": "off",
    "eqeqeq": ["warn", "always"],
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-script-url": "error",
    "no-process-exit": "off",
    "no-useless-catch": "warn",
    "no-prototype-builtins": "warn"
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    "frontend/",
    "logs/",
    "data/",
    "backup/",
    "uploads/"
  ]
}
